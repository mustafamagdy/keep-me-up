{
  "name": "keep-me-up",
  "version": "1.4.0",
  "description": "A simple way to keep your PC awake with no configuration and setup.",
  "main": "index.js",
  "homepage": "https://github.com/mutafow/keep-me-up#readme",
  "scripts": {
    "start": "node index.js",
    "publish-npm": "npm publish --access public",
    "build": "pkg ."
  },
  "bin": "index.js",
  "keywords": [
    "awake",
    "keep pc awake",
    "mouse mover",
    "lightweight",
    "simple awake"
  ],
  "author": "bmutafov",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/mutafow/keep-me-up"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.13"
  },
  "devDependencies": {
    "@types/node": "^17.0.16",
    "eslint": "^8.10.0"
  },
  "pkg": {
    "scripts": "index.js",
    "assets": [
      "package.json"
    ],
    "targets": [
      "node18-macos",
      "node18-linux",
      "node18-win"
    ],
    "outputPath": "build",
    "compress": "GZip"
  }
}
